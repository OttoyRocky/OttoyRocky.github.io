---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Writeups">
  <style>
    .breadcrumb { padding-top: 28px; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--text-dimmer); letter-spacing: 0.5px; }
    .breadcrumb a { color: var(--text-dimmer); text-decoration: none; }
    .breadcrumb a:hover { color: var(--accent); }
    .hero { padding: 28px 0 40px; }
    h1 { font-family: 'JetBrains Mono', monospace; font-weight: 800; font-size: 36px; line-height: 1.2; letter-spacing: -0.5px; margin: 16px 0 14px; }
    .lede { font-size: 16.5px; color: var(--text-dim); max-width: 540px; }
    .empty-box {
      border: 1px dashed var(--border); border-radius: 6px; padding: 32px 24px;
      text-align: center; margin-top: 8px; margin-bottom: 40px;
    }
    .empty-box .mono { font-size: 12.5px; color: var(--text-dimmer); }
  </style>

  <div class="wrap">
    <div class="breadcrumb"><a href="/">otto</a> / writeups</div>

    <section class="hero">
      <span class="eyebrow mono">[WRITEUPS]</span>
      <h1>Bitácora técnica.</h1>
      <p class="lede">
        Notas de proceso sobre metodología, decisiones de arquitectura y hallazgos —
        publicadas solo cuando el disclosure está autorizado.
      </p>
    </section>

    <div class="empty-box">
      <div class="mono">// primer writeup en preparación</div>
    </div>
  </div>

  <Footer />
</BaseLayout>
