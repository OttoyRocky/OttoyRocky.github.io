---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Inicio">
  <style>
    .wrap {
      max-width: 820px;
    }

    /* terminal intro */
    .term-wrap {
      padding: 56px 0 8px;
    }
    .term {
      background: #000;
      border: 1px solid var(--border);
      border-radius: 6px;
      overflow: hidden;
    }
    .term-bar {
      background: var(--bg-raised);
      border-bottom: 1px solid var(--border);
      padding: 9px 14px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .term-dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: var(--border);
    }
    .term-title {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      color: var(--text-dimmer);
      margin-left: 6px;
    }
    .term-body {
      padding: 22px 24px 26px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 13.5px;
      line-height: 1.85;
    }
    .term-prompt {
      color: var(--accent);
    }
    .term-cmd {
      color: var(--text);
    }
    .term-out {
      color: var(--text-dim);
      padding-left: 2px;
    }
    .term-out strong {
      color: var(--text);
      font-weight: 600;
    }
    .cursor {
      display: inline-block;
      width: 7px;
      height: 14px;
      background: var(--accent);
      vertical-align: middle;
      margin-left: 4px;
      animation: blink 1s step-end infinite;
    }
    @keyframes blink {
      50% { opacity: 0; }
    }

    /* thesis */
    .thesis-block {
      padding: 44px 0 8px;
    }
    .thesis-block h1 {
      font-family: 'JetBrains Mono', monospace;
      font-weight: 800;
      font-size: 38px;
      line-height: 1.2;
      letter-spacing: -0.5px;
      max-width: 620px;
    }
    .thesis-block h1 .accent-text {
      color: var(--accent);
    }
    .thesis-sub {
      font-size: 16.5px;
      color: var(--text-dim);
      max-width: 540px;
      margin-top: 18px;
    }
    .cta-row {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 28px;
    }

    .position-line {
      margin-top: 22px;
      max-width: 560px;
      font-size: 14px;
      color: var(--text-dim);
      line-height: 1.6;
      padding-left: 14px;
      border-left: 2px solid var(--accent-dim);
    }
    .position-tag {
      display: block;
      font-size: 10px;
      color: var(--accent);
      letter-spacing: 1px;
      margin-bottom: 6px;
    }

    .stack-strip {
      padding: 28px 0 8px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .stack-strip-row {
      display: flex;
      align-items: baseline;
      gap: 16px;
      flex-wrap: wrap;
    }
    .stack-strip-label {
      font-size: 10.5px;
      color: var(--text-dimmer);
      letter-spacing: 1px;
      flex: 0 0 78px;
    }
    .stack-strip-items {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
    }

    /* metrics strip */
    .metrics {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      margin-top: 48px;
    }
    .metric {
      padding: 22px 18px;
      border-right: 1px solid var(--border);
    }
    .metric:last-child {
      border-right: none;
    }
    .metric-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 26px;
      font-weight: 700;
      color: var(--accent);
    }
    .metric-label {
      font-size: 10.5px;
      color: var(--text-dimmer);
      letter-spacing: 0.3px;
      margin-top: 4px;
      line-height: 1.4;
    }

    /* projects section */
    .section-head {
      padding: 56px 0 8px;
      display: flex;
      align-items: baseline;
      justify-content: space-between;
    }
    .section-link {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11.5px;
      color: var(--text-dimmer);
      text-decoration: none;
    }
    .section-link:hover {
      color: var(--accent);
    }

    .project-list {
      padding: 18px 0 8px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .project-card {
      display: block;
      text-decoration: none;
      background: var(--bg-raised);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 20px 22px;
      transition: border-color 0.15s ease;
    }
    .project-card:hover {
      border-color: var(--accent-dim);
    }
    .pc-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 8px;
    }
    .pc-name {
      font-family: 'JetBrains Mono', monospace;
      font-size: 16px;
      font-weight: 700;
      color: var(--text);
    }
    .pc-status {
      display: flex;
      align-items: center;
      gap: 6px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 10.5px;
      color: var(--text-dimmer);
      letter-spacing: 0.4px;
      white-space: nowrap;
    }
    .pc-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
    }
    .pc-dot.green {
      background: var(--green-status);
      box-shadow: 0 0 6px var(--green-status);
    }
    .pc-dot.yellow {
      background: var(--yellow-status);
    }
    .pc-desc {
      font-size: 13.5px;
      color: var(--text-dim);
      margin-bottom: 12px;
      max-width: 540px;
    }
    .pc-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
    }
    .pc-tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10.5px;
      color: var(--text-dimmer);
      border: 1px solid var(--border);
      padding: 3px 9px;
      border-radius: 3px;
    }

    /* about teaser */
    .about-teaser {
      padding: 56px 0 8px;
    }
    .about-card {
      background: var(--bg-raised);
      border: 1px solid var(--border);
      border-left: 2px solid var(--accent);
      border-radius: 6px;
      padding: 24px 26px;
    }
    .about-card p {
      font-size: 14.5px;
      color: var(--text-dim);
      max-width: 580px;
      margin-bottom: 14px;
    }
    .about-card p strong {
      color: var(--text);
    }
    .about-card a {
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      color: var(--accent);
      text-decoration: none;
    }
    .about-card a:hover {
      text-decoration: underline;
    }

    @media (max-width: 640px) {
      .thesis-block h1 {
        font-size: 28px;
      }
      .metrics {
        grid-template-columns: repeat(2, 1fr);
      }
      .metric {
        border-bottom: 1px solid var(--border);
      }
      .stack-strip-row {
        flex-direction: column;
        gap: 6px;
      }
      .stack-strip-label {
        flex: none;
      }
      .term-body {
        font-size: 12px;
      }
    }
  </style>

  <div class="wrap">
    <div class="term-wrap">
      <div class="term">
        <div class="term-bar">
          <div class="term-dot"></div><div class="term-dot"></div><div class="term-dot"></div>
          <div class="term-title">otto@root:~</div>
        </div>
        <div class="term-body">
          <div><span class="term-prompt">$</span> <span class="term-cmd">whoami</span></div>
          <div class="term-out">&gt; <strong>OTTO</strong> · Security Researcher &amp; Tool Builder</div>
          <div class="term-out">&gt; Bug Bounty: Bugcrowd / HackerOne (otto866)</div>
          <div style="height:8px"></div>
          <div><span class="term-prompt">$</span> <span class="term-cmd">cat mision.txt</span></div>
          <div class="term-out">&gt; No resuelvo retos, construyo lo que automatiza</div>
          <div class="term-out">&gt; el proceso de encontrarlos.<span class="cursor"></span></div>
        </div>
      </div>
    </div>

    <section class="thesis-block">
      <h1>Construyo las herramientas<br>que <span class="accent-text">automatizan</span><br>la seguridad ofensiva.</h1>
      <p class="thesis-sub">
        Framework de pentesting con IA local, pipelines de recon para bug bounty y un
        copiloto ofensivo que nunca toca la nube. Tres proyectos open source, código real,
        decisiones explicadas.
      </p>
      <p class="position-line">
        <span class="position-tag mono">POSICIONAMIENTO</span>
        No construyo herramientas en el vacío — las pruebo en programas reales de bug
        bounty (Bugcrowd, HackerOne). Cada decisión de arquitectura está validada contra
        targets en producción, no solo contra un laboratorio.
      </p>
      <div class="cta-row">
        <a href="/proyectos" class="btn btn-primary">→ Ver proyectos</a>
        <a href="/sobre-otto" class="btn btn-secondary">Sobre OTTO</a>
      </div>
    </section>

    <div class="metrics">
      <div class="metric">
        <div class="metric-num mono">3</div>
        <div class="metric-label">HERRAMIENTAS<br>PROPIAS</div>
      </div>
      <div class="metric">
        <div class="metric-num mono">3</div>
        <div class="metric-label">PROGRAMAS DE<br>BUG BOUNTY ACTIVOS</div>
      </div>
      <div class="metric">
        <div class="metric-num mono">14/14</div>
        <div class="metric-label">TESTS PASANDO<br>(PHANTOM BRAIN)</div>
      </div>
      <div class="metric">
        <div class="metric-num mono">100%</div>
        <div class="metric-label">IA CORRIENDO<br>LOCAL</div>
      </div>
    </div>

    <div class="stack-strip">
      <div class="stack-strip-row">
        <span class="stack-strip-label mono">LENGUAJES</span>
        <div class="stack-strip-items">
          <span class="badge">PYTHON</span><span class="badge">BASH</span>
        </div>
      </div>
      <div class="stack-strip-row">
        <span class="stack-strip-label mono">OFENSIVA</span>
        <div class="stack-strip-items">
          <span class="badge">BURP SUITE</span><span class="badge">NUCLEI</span><span class="badge">SUBFINDER</span><span class="badge">DALFOX</span><span class="badge">HASHCAT</span><span class="badge">AIRCRACK-NG</span>
        </div>
      </div>
      <div class="stack-strip-row">
        <span class="stack-strip-label mono">IA / INFRA</span>
        <div class="stack-strip-items">
          <span class="badge">OLLAMA</span><span class="badge">FLASK</span><span class="badge">SQLITE</span><span class="badge">LINUX</span><span class="badge">TAILSCALE</span>
        </div>
      </div>
      <div class="stack-strip-row">
        <span class="stack-strip-label mono">HARDWARE</span>
        <div class="stack-strip-items">
          <span class="badge">FLIPPER ZERO</span><span class="badge">WIFI PINEAPPLE</span><span class="badge">PROXMARK3</span>
        </div>
      </div>
    </div>

    <div class="section-head" id="proyectos">
      <div class="section-label">PROYECTOS</div>
      <a href="/proyectos" class="section-link">ver todos →</a>
    </div>

    <div class="project-list">
      <a href="/proyectos/phantom-brain" class="project-card">
        <div class="pc-top">
          <span class="pc-name mono">phantom-brain</span>
          <span class="pc-status mono"><span class="pc-dot green"></span>v0.9 · ACTIVO</span>
        </div>
        <p class="pc-desc">Asistente de pentesting con IA local que analiza capturas WiFi, NFC y Sub-GHz sin salir del hardware del operador.</p>
        <div class="pc-tags">
          <span class="pc-tag">PYTHON</span><span class="pc-tag">FLASK</span><span class="pc-tag">OLLAMA</span>
        </div>
      </a>

      <a href="/proyectos/bounty-hunter" class="project-card">
        <div class="pc-top">
          <span class="pc-name mono">bounty-hunter</span>
          <span class="pc-status mono"><span class="pc-dot green"></span>PRODUCCIÓN</span>
        </div>
        <p class="pc-desc">Pipeline de reconocimiento automatizado para bug bounty: descubrimiento, verificación, escaneo y priorización con IA.</p>
        <div class="pc-tags">
          <span class="pc-tag">SUBFINDER</span><span class="pc-tag">NUCLEI</span><span class="pc-tag">DALFOX</span>
        </div>
      </a>

      <a href="/proyectos/hacxgpt" class="project-card">
        <div class="pc-top">
          <span class="pc-name mono">hacxgpt</span>
          <span class="pc-status mono"><span class="pc-dot yellow"></span>v8.1 · EN DESARROLLO</span>
        </div>
        <p class="pc-desc">Copiloto de IA local para trabajo ofensivo — sugiere comandos, interpreta resultados de nmap, sin telemetría.</p>
        <div class="pc-tags">
          <span class="pc-tag">MISTRAL:7B</span><span class="pc-tag">TINYLLAMA</span>
        </div>
      </a>
    </div>

    <div class="about-teaser">
      <div class="about-card">
        <p>
          <strong>17 años analizando patrones neurológicos. Ahora analizo patrones de
          ataque.</strong> La transición desde neurofisiología clínica hacia seguridad
          ofensiva no fue un cambio de rubro — fue aplicar la misma disciplina de
          observación a un dominio distinto.
        </p>
        <a href="/sobre-otto">leer la historia completa →</a>
      </div>
    </div>
  </div>

  <footer style="border-top: 1px solid var(--border); margin-top: 40px; padding: 28px 0 48px;">
    <div class="wrap" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px; font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--text-dimmer);">
      <span>OTTO · constructor de herramientas · BA, Argentina</span>
      <div style="display:flex; gap:22px;">
        <a href="https://github.com/OttoyRocky" style="color:var(--text-dim); text-decoration:none;">GitHub</a>
        <a href="https://bugcrowd.com/h/ottopavlovb2c70c3c-bb09-45ee-9ea2-bc187713b773" style="color:var(--text-dim); text-decoration:none;">Bugcrowd</a>
        <a href="/contacto" style="color:var(--text-dim); text-decoration:none;">Contacto</a>
      </div>
    </div>
  </footer>
</BaseLayout>
