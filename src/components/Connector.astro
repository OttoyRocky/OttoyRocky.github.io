<style>
  .connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 36px;
    position: relative;
  }
  .connector-line {
    width: 1px;
    height: 100%;
    background: linear-gradient(to bottom, var(--border), var(--accent-dim));
  }
  .connector-node {
    position: absolute;
    bottom: -1px;
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
    box-shadow: 0 0 6px var(--accent-glow);
  }
</style>

<div class="connector">
  <div class="connector-line"></div>
  <div class="connector-node"></div>
</div>
